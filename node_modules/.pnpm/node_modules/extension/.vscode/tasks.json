{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm: watch",
            "type": "shell",
            // 运行 packages/extension/package.json 中的 watch 脚本
            "command": "pnpm run watch",
            "isBackground": true,
            "presentation": {
                "reveal": "never",
                "panel": "dedicated"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": "$tsc-watch"
        }
    ]
}