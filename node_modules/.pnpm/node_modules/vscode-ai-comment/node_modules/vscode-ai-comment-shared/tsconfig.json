{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "src",
    "composite": true,         // 必须开启，消除 TS6306
    "noEmit": false,
    "declaration": true,       // 必须开启 (你已经开了)
    "declarationMap": true,    // 建议开启，允许从 extension 跳转源码
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"] // 确保排除输出目录
}