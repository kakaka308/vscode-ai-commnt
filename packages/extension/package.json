{
  "name": "vscode-ai-comment",
  "displayName": "AI Comment Generator",
  "description": "AI-powered comment generator for multiple languages",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ai-comment.generateSelected",
    "onCommand:ai-comment.generateWholeFile",
    "onCommand:ai-comment.openConfig"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-comment.generateSelected",
        "title": "AI Comment: Generate for Selected Code"
      },
      {
        "command": "ai-comment.generateWholeFile",
        "title": "AI Comment: Generate for Whole File"
      },
      {
        "command": "ai-comment.openConfig",
        "title": "AI Comment: Settings"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ai-comment.generateSelected",
          "group": "ai-comment",
          "when": "editorHasSelection"
        },
        {
          "command": "ai-comment.generateWholeFile",
          "group": "ai-comment",
          "when": "resourceLangId"
        },
        {
          "command": "ai-comment.openConfig",
          "group": "ai-comment",
          "when": "resourceLangId"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-comment.generateSelected",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "ai-comment.generateWholeFile",
        "key": "ctrl+alt+/",
        "mac": "cmd+alt+/",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "AI Comment Generator",
      "type": "object",
      "properties": {
        "aiComment.apiKey": { "type": "string", "description": "Default/OpenAI API Key" },
        "aiComment.model": { "type": "string", "default": "gpt-3.5-turbo", "description": "Default Model" },
        "aiComment.commentStyle": { "type": "string", "default": "default", "description": "Comment Style" },
        "aiComment.commentMode": { "type": "string", "default": "concise", "description": "Comment Mode" },
        "aiComment.targetLanguage": { "type": "string", "default": "auto", "description": "Target Language" },
        "aiComment.aiProvider": { "type": "string", "default": "openai", "description": "AI Provider" },
        
        "aiComment.openaiApiKey": { "type": "string", "description": "OpenAI API Key" },
        "aiComment.openaiModel": { "type": "string", "default": "gpt-3.5-turbo" },
        "aiComment.openaiEndpoint": { "type": "string" },
        
        "aiComment.qwenApiKey": { "type": "string", "description": "Qwen API Key" },
        "aiComment.qwenModel": { "type": "string", "default": "qwen-turbo" },
        "aiComment.qwenEndpoint": { "type": "string" },
        
        "aiComment.baiduApiKey": { "type": "string" },
        "aiComment.baiduSecretKey": { "type": "string" },
        "aiComment.baiduModel": { "type": "string", "default": "ernie-4.0" },
        
        "aiComment.xunfeiAppId": { "type": "string" },
        "aiComment.xunfeiApiKey": { "type": "string" },
        "aiComment.xunfeiApiSecret": { "type": "string" }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "tsc -p ./ && pnpm run copy-ui",
    "watch": "tsc -watch -p ./",
    "copy-ui": "node -e \"const fs=require('fs'); const path=require('path'); const src=path.join('..','ui','dist'); const dest=path.join('dist','ui'); try { fs.rmSync(dest, {recursive:true, force:true}); fs.mkdirSync(dest, {recursive:true}); fs.cpSync(src, dest, {recursive:true}); console.log('UI assets copied successfully.'); } catch(e) { console.error('Copy failed:', e); process.exit(1); }\"",
    "pretest": "pnpm run build && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "~18.19.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.49.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "vscode-ai-comment-shared": "workspace:*"
  }
}