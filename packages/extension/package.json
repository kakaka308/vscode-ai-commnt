{
  "name": "extension",
  "displayName": "AI Comment Generator",
  "description": "AI-powered comment generator for multiple languages",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:ai-comment.generateSelected",
    "onCommand:ai-comment.generateWholeFile",
    "onCommand:ai-comment.openConfig"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ai-comment.generateSelected",
        "title": "AI Comment: Generate for Selected Code"
      },
      {
        "command": "ai-comment.generateWholeFile",
        "title": "AI Comment: Generate for Whole File"
      },
      {
        "command": "ai-comment.openConfig",
        "title": "AI Comment: Settings"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ai-comment.generateSelected",
          "group": "ai-comment",
          "when": "editorHasSelection"
        },
        {
          "command": "ai-comment.generateWholeFile",
          "group": "ai-comment",
          "when": "resourceLangId"
        },
        {
          "command": "ai-comment.openConfig",
          "group": "ai-comment",
          "when": "resourceLangId"
        }
      ]
    },
    "keybindings": [
      {
        "command": "ai-comment.generateSelected",
        "key": "ctrl+shift+/",
        "mac": "cmd+shift+/",
        "when": "editorTextFocus && editorHasSelection"
      },
      {
        "command": "ai-comment.generateWholeFile",
        "key": "ctrl+alt+/",
        "mac": "cmd+alt+/",
        "when": "editorTextFocus"
      }
    ],
    "configuration": {
      "title": "AI Comment Generator",
      "type": "object",
      "properties": {
        "aiComment.apiKey": {
          "type": "string",
          "description": "OpenAI API Key",
          "order": 1
        },
        "aiComment.model": {
          "type": "string",
          "default": "gpt-3.5-turbo",
          "description": "OpenAI 模型名称",
          "order": 2
        },
        "aiComment.openaiEndpoint": {
          "type": "string",
          "default": "https://api.openai.com/v1/chat/completions",
          "description": "OpenAI Endpoint（代理地址可在此修改）",
          "order": 3
        },
        "aiComment.aiProvider": {
          "type": "string",
          "default": "openai",
          "enum": ["openai", "qwen", "baidu"],
          "enumDescriptions": ["OpenAI", "通义千问", "文心一言"],
          "description": "AI 服务商",
          "order": 4
        },
        "aiComment.commentMode": {
          "type": "string",
          "default": "concise",
          "enum": ["concise", "detailed"],
          "enumDescriptions": ["简洁模式：一句话总结", "详细模式：完整注释块"],
          "description": "注释模式",
          "order": 5
        },
        "aiComment.commentStyle": {
          "type": "string",
          "default": "default",
          "enum": ["default", "javadoc", "jsdoc", "godoc", "doxygen", "docstring"],
          "description": "注释风格（default 为根据语言自动选择）",
          "order": 6
        },
        "aiComment.targetLanguage": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "java", "javascript", "typescript", "python", "go", "cpp", "c"],
          "description": "目标语言（auto 为自动检测）",
          "order": 7
        },
        "aiComment.qwenApiKey": {
          "type": "string",
          "description": "通义千问 API Key",
          "order": 8
        },
        "aiComment.qwenModel": {
          "type": "string",
          "default": "qwen-turbo",
          "enum": ["qwen-turbo", "qwen-plus", "qwen-max", "qwen-long"],
          "description": "通义千问模型",
          "order": 9
        },
        "aiComment.qwenEndpoint": {
          "type": "string",
          "default": "https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions",
          "description": "通义千问 Endpoint",
          "order": 10
        },
        "aiComment.baiduApiKey": {
          "type": "string",
          "description": "文心一言 API Key",
          "order": 11
        },
        "aiComment.baiduSecretKey": {
          "type": "string",
          "description": "文心一言 Secret Key",
          "order": 12
        },
        "aiComment.baiduModel": {
          "type": "string",
          "default": "ernie-4.0",
          "enum": ["ernie-4.0", "ernie-3.5", "ernie-lite"],
          "description": "文心一言模型",
          "order": 13
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run build",
    "build": "tsc -p ./ && pnpm run copy:ui",
    "copy:ui": "node -e \"const fs=require('fs');fs.cpSync('../ui/dist','./ui-dist',{recursive:true})\"",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run build && pnpm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "~18.19.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vscode/test-electron": "^2.3.4",
    "eslint": "^8.49.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.2.2"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "shared": "workspace:*"
  }
}